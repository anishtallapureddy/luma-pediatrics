---
import { Icon } from 'astro-icon/components';
import { SITE } from '../site.config';
---
<section class="rounded-[var(--radius-card)] bg-[var(--color-card)] ring-1 ring-[var(--color-border-soft)] p-7 md:p-8">
  <div class="flex items-center gap-2 text-[var(--color-primary)]">
    <Icon name="lucide:file-text" class="w-5 h-5" stroke-width="1.8" aria-hidden="true" />
    <span class="eyebrow eyebrow-sun">Patient forms</span>
  </div>
  <h2 class="mt-4 text-2xl md:text-3xl font-extrabold tracking-tight">
    Download forms ahead of your first visit
  </h2>
  <p class="mt-3 text-[var(--color-foreground)]/85 leading-relaxed">
    Fill these out at home to save time at check-in. Bring the completed forms with you,
    or email them ahead to <a href={SITE.contact.emailHref}>{SITE.contact.email}</a>.
  </p>

  <ul class="mt-6 grid gap-3 sm:grid-cols-2">
    {SITE.patientForms.map(({ file, label }) => (
      <li>
        <a
          href={file}
          download
          class="card-lift group flex items-center justify-between gap-4 rounded-xl bg-[var(--color-background)] p-4 ring-1 ring-[var(--color-border-soft)] no-underline"
        >
          <span class="flex items-center gap-3">
            <span
              class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-muted)] text-[var(--color-primary)] shrink-0"
              aria-hidden="true"
            >
              <Icon name="lucide:file-text" class="w-5 h-5" stroke-width="1.6" />
            </span>
            <span class="text-sm md:text-base font-semibold text-[var(--color-foreground)] leading-snug">
              {label}
            </span>
          </span>
          <Icon name="lucide:download" class="w-4 h-4 text-[var(--color-muted-foreground)] group-hover:text-[var(--color-primary)]" stroke-width="1.8" aria-hidden="true" />
        </a>
      </li>
    ))}
  </ul>

  <p class="mt-5 text-xs text-[var(--color-muted-foreground)]">
    These are placeholder previews ahead of our Fall 2026 opening. Final forms will be available before your first appointment.
  </p>
</section>
