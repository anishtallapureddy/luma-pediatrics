---
import { Icon } from 'astro-icon/components';
import { SITE } from '../site.config';

interface Props {
  variant?: 'hero' | 'inline';
  title?: string;
  blurb?: string;
}

const { variant = 'inline', title, blurb } = Astro.props;

/**
 * Founding-families waitlist form.
 *
 * Submits (via AJAX) to a Google Apps Script Web App that appends each signup
 * to a Google Sheet — see docs/waitlist-setup.md. When SITE.forms.waitlistEndpoint
 * is empty the form degrades gracefully to a "call us" prompt (no mailto).
 */
const endpoint = (SITE.forms.waitlistEndpoint ?? '').trim();

const headline = title ?? 'Join the founding-families list';
const intro =
  blurb ??
  `Luma Pediatrics opens ${SITE.openingWindow} in ${SITE.locationShort}. Share your details and we'll notify you the moment scheduling opens — and answer any early questions about establishing care.`;

const isHero = variant === 'hero';
const inputClass =
  'mt-1 w-full min-h-11 px-3 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none';
---
<section class:list={['waitlist-card rounded-[var(--radius-card)] p-7 md:p-9', isHero ? 'waitlist-hero ring-1 ring-[var(--color-border-soft)] bg-[var(--color-card)]' : 'bg-[var(--color-card)] ring-1 ring-[var(--color-border-soft)]']}>
  <div class="flex items-center gap-2 text-[var(--color-primary)]">
    <Icon name="lucide:sparkles" class="w-5 h-5" stroke-width="1.8" aria-hidden="true" />
    <span class="eyebrow eyebrow-sun">Founding families</span>
  </div>
  <h2 class:list={['mt-4 font-extrabold tracking-tight', isHero ? 'text-3xl md:text-4xl' : 'text-2xl md:text-3xl']}>
    {headline}
  </h2>
  <p class="mt-3 text-[var(--color-foreground)]/85 leading-relaxed">
    {intro}
  </p>

  <form
    class="mt-6 grid gap-4 sm:grid-cols-2"
    data-waitlist-form
    data-endpoint={endpoint}
    data-phone={SITE.contact.phone}
    novalidate
  >
    {/* Honeypot — bots fill this; humans never see it. */}
    <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Parent / guardian name <span class="text-[var(--color-muted-foreground)] font-normal">(optional)</span></span>
      <input type="text" name="parent_name" autocomplete="name" class={inputClass} />
    </label>
    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Email</span>
      <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" class={inputClass} />
    </label>
    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Child's age or due date <span class="text-[var(--color-muted-foreground)] font-normal">(optional)</span></span>
      <input type="text" name="child_age_or_due" placeholder="e.g. 4 months, due April 2026" class={inputClass} />
    </label>
    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">City <span class="text-[var(--color-muted-foreground)] font-normal">(optional)</span></span>
      <input type="text" name="city" autocomplete="address-level2" placeholder="McKinney, Frisco, Allen…" class={inputClass} />
    </label>

    <div class="sm:col-span-2 flex items-center gap-3 flex-wrap">
      <button
        type="submit"
        data-waitlist-submit
        class="inline-flex items-center justify-center gap-2 min-h-11 px-6 rounded-full bg-[var(--color-primary)] text-white font-semibold hover:brightness-110 focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 outline-none disabled:opacity-70 disabled:cursor-not-allowed"
      >
        <Icon name="lucide:send" class="w-4 h-4" stroke-width="1.8" aria-hidden="true" />
        <span data-waitlist-submit-label>Join the waitlist</span>
      </button>
      <p class="text-xs text-[var(--color-muted-foreground)]">
        We'll only use your info to share opening news. Unsubscribe anytime.
      </p>
    </div>

    <p data-waitlist-error class="sm:col-span-2 hidden text-sm font-semibold text-[var(--color-destructive)]" role="alert"></p>
  </form>

  <div
    data-waitlist-success
    class="hidden mt-6 flex items-start gap-3 rounded-[var(--radius-card)] bg-[var(--color-muted)] ring-1 ring-[var(--color-border-soft)] p-5"
    role="status"
    aria-live="polite"
  >
    <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-full bg-[var(--color-primary)] text-white" aria-hidden="true">
      <Icon name="lucide:check" class="w-5 h-5" stroke-width="2.4" />
    </span>
    <div>
      <p class="font-extrabold text-[var(--color-foreground)]">You're on the list!</p>
      <p class="mt-1 text-sm text-[var(--color-foreground)]/80 leading-relaxed">
        Thanks for joining our founding families. We'll email you the moment scheduling opens.
      </p>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('form[data-waitlist-form]').forEach((form) => {
    const section = form.closest('section');
    const successEl = section ? section.querySelector('[data-waitlist-success]') : null;
    const errorEl = form.querySelector('[data-waitlist-error]');
    const btn = form.querySelector('[data-waitlist-submit]');
    const label = form.querySelector('[data-waitlist-submit-label]');
    const endpoint = (form.getAttribute('data-endpoint') || '').trim();
    const phone = form.getAttribute('data-phone') || '';
    const EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

    const showError = (msg) => {
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorEl) {
        errorEl.textContent = '';
        errorEl.classList.add('hidden');
      }

      const data = new FormData(form);
      if (data.get('botcheck')) return; // honeypot tripped — silently ignore

      const email = (data.get('email') || '').toString().trim();
      if (!EMAIL_RE.test(email)) {
        showError('Please enter a valid email address.');
        return;
      }

      if (!endpoint) {
        showError('Online signup is being set up — please call ' + phone + ' and we\u2019ll add you.');
        return;
      }

      const original = label ? label.textContent : '';
      if (btn) btn.disabled = true;
      if (label) label.textContent = 'Joining\u2026';

      data.append('page', window.location.pathname);
      data.append('submitted_at', new Date().toISOString());

      try {
        // Apps Script Web Apps don't return CORS headers, so we fire-and-forget
        // with no-cors; the row is still written to the Sheet.
        await fetch(endpoint, { method: 'POST', mode: 'no-cors', body: data });
        form.classList.add('hidden');
        if (successEl) {
          successEl.classList.remove('hidden');
          successEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      } catch (err) {
        if (btn) btn.disabled = false;
        if (label) label.textContent = original;
        showError('Something went wrong. Please try again, or call us at ' + phone + '.');
      }
    });
  });
</script>
