---
/**
 * Newsletter signup — Mailchimp embedded form pattern.
 * If SITE.newsletter.mailchimpAction is empty, renders a placeholder card
 * with a "coming soon" disabled state so the visual presence is still there
 * but no broken submission can occur.
 */
import { Icon } from 'astro-icon/components';
import { SITE } from '../site.config';

const configured =
  !!SITE.newsletter.mailchimpAction &&
  !!SITE.newsletter.mailchimpUserId &&
  !!SITE.newsletter.mailchimpListId;

const action = configured
  ? `${SITE.newsletter.mailchimpAction}?u=${SITE.newsletter.mailchimpUserId}&id=${SITE.newsletter.mailchimpListId}`
  : '';
---
<section class="newsletter-signup">
  <div class="flex items-center gap-2 text-[var(--color-primary)]">
    <Icon name="lucide:mail" class="w-4 h-4" stroke-width="1.8" aria-hidden="true" />
    <span class="eyebrow eyebrow-sun">Newsletter</span>
  </div>
  <h3 class="mt-3 text-lg font-extrabold">Get monthly Luma tips</h3>
  <p class="mt-2 text-sm text-[var(--color-muted-foreground)] leading-relaxed">
    {SITE.newsletter.pitch}
  </p>

  {configured ? (
    <form
      action={action}
      method="post"
      target="_blank"
      novalidate
      class="mt-4 flex gap-2 flex-wrap"
    >
      <label class="sr-only" for="mce-EMAIL">Email address</label>
      <input
        id="mce-EMAIL"
        name="EMAIL"
        type="email"
        required
        placeholder="you@example.com"
        class="flex-1 min-w-0 min-h-11 px-4 rounded-full bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] text-base sm:text-sm focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      />
      {/* Honeypot to deter bots, per Mailchimp recommendation */}
      <div aria-hidden="true" style="position:absolute;left:-5000px;">
        <input type="text" name={`b_${SITE.newsletter.mailchimpUserId}_${SITE.newsletter.mailchimpListId}`} tabindex="-1" value="" />
      </div>
      <button
        type="submit"
        class="inline-flex items-center gap-1.5 min-h-11 px-5 rounded-full bg-[var(--color-primary)] text-white font-semibold text-sm hover:opacity-92"
      >
        <Icon name="lucide:send" class="w-4 h-4" stroke-width="1.8" />
        Subscribe
      </button>
    </form>
  ) : (
    <div class="mt-4 rounded-full bg-[var(--color-muted)] ring-1 ring-inset ring-[var(--color-border-soft)] p-1 flex gap-2 flex-wrap" aria-disabled="true">
      <input
        type="email"
        placeholder="Signup opens soon"
        disabled
        class="flex-1 min-w-0 min-h-9 px-4 bg-transparent text-base sm:text-sm text-[var(--color-muted-foreground)] outline-none"
      />
      <span class="inline-flex items-center gap-1.5 min-h-9 px-4 rounded-full bg-[var(--color-foreground)]/15 text-[var(--color-foreground)]/60 font-semibold text-sm cursor-not-allowed">
        Coming soon
      </span>
    </div>
  )}
</section>
