---
/**
 * Insurance verification micro-form.
 * Submits to Web3Forms when SITE.forms.web3formsAccessKey is configured;
 * otherwise falls back to a mailto: prefilled email.
 * Intentionally non-PHI: only insurance + contact info, no medical detail.
 */
import { Icon } from 'astro-icon/components';
import { SITE } from '../site.config';

const w3fConfigured =
  !!SITE.forms.web3formsAccessKey &&
  SITE.forms.web3formsAccessKey !== 'REPLACE_WITH_WEB3FORMS_ACCESS_KEY';

const action = w3fConfigured ? 'https://api.web3forms.com/submit' : SITE.contact.emailHref;
---
<section class="rounded-[var(--radius-card)] bg-[var(--color-card)] ring-1 ring-[var(--color-border-soft)] p-7 md:p-8">
  <div class="flex items-center gap-2 text-[var(--color-primary)]">
    <Icon name="lucide:shield-check" class="w-5 h-5" stroke-width="1.8" aria-hidden="true" />
    <span class="eyebrow eyebrow-sun">Insurance check</span>
  </div>
  <h2 class="mt-4 text-2xl md:text-3xl font-extrabold tracking-tight">
    Not sure if we take your plan?
  </h2>
  <p class="mt-3 text-[var(--color-foreground)]/85 leading-relaxed">
    Send us your plan details and we'll verify your coverage before your first visit — usually within one business day.
  </p>

  <form
    action={action}
    method={w3fConfigured ? 'POST' : 'get'}
    class="mt-6 grid gap-4 sm:grid-cols-2"
  >
    {w3fConfigured && (
      <>
        <input type="hidden" name="access_key" value={SITE.forms.web3formsAccessKey} />
        <input type="hidden" name="subject" value="Insurance verification request" />
        <input type="hidden" name="from_name" value="Luma Pediatrics website" />
        <input type="hidden" name="redirect" value="/contact?status=verify-thanks" />
      </>
    )}
    {/* Honeypot */}
    <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Parent / guardian name</span>
      <input
        type="text"
        name="parent_name"
        required
        autocomplete="name"
        class="mt-1 w-full min-h-11 px-3 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      />
    </label>
    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Email</span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        class="mt-1 w-full min-h-11 px-3 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      />
    </label>

    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Phone <span class="font-normal text-[var(--color-muted-foreground)]">(optional)</span></span>
      <input
        type="tel"
        name="phone"
        autocomplete="tel"
        class="mt-1 w-full min-h-11 px-3 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      />
    </label>
    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Insurance carrier</span>
      <input
        type="text"
        name="insurance_carrier"
        placeholder="e.g., Blue Cross Blue Shield of Texas"
        required
        class="mt-1 w-full min-h-11 px-3 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      />
    </label>

    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Plan name <span class="font-normal text-[var(--color-muted-foreground)]">(optional)</span></span>
      <input
        type="text"
        name="plan_name"
        placeholder="e.g., BlueChoice PPO"
        class="mt-1 w-full min-h-11 px-3 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      />
    </label>
    <label class="block sm:col-span-1">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Member ID <span class="font-normal text-[var(--color-muted-foreground)]">(optional)</span></span>
      <input
        type="text"
        name="member_id"
        class="mt-1 w-full min-h-11 px-3 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      />
    </label>

    <label class="block sm:col-span-2">
      <span class="text-sm font-semibold text-[var(--color-foreground)]">Notes <span class="font-normal text-[var(--color-muted-foreground)]">(optional)</span></span>
      <textarea
        name="notes"
        rows="3"
        placeholder="Anything else we should know? (No medical detail, please.)"
        class="mt-1 w-full px-3 py-2 rounded-lg bg-[var(--color-background)] ring-1 ring-[var(--color-border-soft)] focus:ring-2 focus:ring-[var(--color-primary)] outline-none"
      ></textarea>
    </label>

    <div class="sm:col-span-2 flex flex-wrap items-center gap-3 mt-1">
      <button
        type="submit"
        class="inline-flex items-center gap-2 min-h-11 px-5 rounded-[var(--radius-button)] bg-[var(--color-primary)] text-white font-semibold hover:opacity-92"
      >
        <Icon name="lucide:send" class="w-4 h-4" stroke-width="1.8" />
        Send for verification
      </button>
      <p class="text-xs text-[var(--color-muted-foreground)] leading-relaxed">
        Do not include your child's medical history here. We typically reply within one business day.
      </p>
    </div>
  </form>
</section>
