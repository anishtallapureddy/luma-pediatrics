---
import { Icon } from 'astro-icon/components';
import Logo from './Logo.astro';
import FeatureTrio from './FeatureTrio.astro';
import NewsletterSignup from './NewsletterSignup.astro';
import { SITE } from '../site.config';

const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-[rgba(200, 153, 90,0.18)] bg-[var(--color-background)]">
  <div class="bg-[var(--color-sage-light)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <FeatureTrio onSage />
    </div>
  </div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid gap-10 md:grid-cols-5">
      <div class="md:col-span-2">
        <Logo variant="horizontal" size={46} />
        <p class="mt-4 text-sm text-[var(--color-muted-foreground)] max-w-xs leading-relaxed">
          {SITE.tagline} Compassionate pediatric care from newborns to teens.
        </p>
        <p class="mt-3 inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-primary)] bg-[var(--color-muted)] rounded-full px-2.5 py-1">
          <Icon name="lucide:sparkles" class="w-3.5 h-3.5" stroke-width="1.8" aria-hidden="true" />
          {SITE.status} · {SITE.locationShort}
        </p>
        <div class="mt-6 max-w-sm">
          <NewsletterSignup />
        </div>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-[var(--color-muted-foreground)]">
          Visit Us
        </h3>
        <address class="not-italic mt-3 text-sm leading-6 text-[var(--color-foreground)]">
          {SITE.address.street}<br />
          {SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}
        </address>
        <p class="mt-3 text-sm">
          <a href={SITE.contact.phoneHref} class="inline-flex items-center gap-1.5 no-underline">
            <Icon name="lucide:phone" class="w-4 h-4" stroke-width="1.6" aria-hidden="true" />
            {SITE.contact.phone}
          </a>
        </p>
        <p class="text-sm">
          <a href={SITE.contact.emailHref} class="inline-flex items-center gap-1.5 no-underline">
            <Icon name="lucide:mail" class="w-4 h-4" stroke-width="1.6" aria-hidden="true" />
            {SITE.contact.email}
          </a>
        </p>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-[var(--color-muted-foreground)]">
          Office Hours
        </h3>
        <dl class="mt-3 text-sm text-[var(--color-foreground)] space-y-1">
          {SITE.hours.map(({ day, time }) => (
            <div class="flex justify-between gap-3"><dt>{day}</dt><dd>{time}</dd></div>
          ))}
        </dl>
        <p class="mt-3 text-sm font-medium text-[var(--color-primary)]">
          Same-day sick visits available — call our office.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wide text-[var(--color-muted-foreground)]">
          Site
        </h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/about" class="no-underline">About</a></li>
          <li><a href="/services" class="no-underline">Services</a></li>
          <li><a href="/vaccines" class="no-underline">Vaccine schedule</a></li>
          <li><a href="/new-patients" class="no-underline">New Patients</a></li>
          <li><a href="/faq" class="no-underline">FAQ</a></li>
          <li><a href="/contact" class="no-underline">Contact</a></li>
          <li><a href="/privacy" class="no-underline">Privacy</a></li>
          <li><a href="/notice-of-privacy-practices" class="no-underline">Notice of Privacy Practices</a></li>
          <li><a href="/accessibility" class="no-underline">Accessibility</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-border-soft)] text-xs text-[var(--color-muted-foreground)] space-y-2">
      <p>
        <strong class="text-[var(--color-foreground)]">Serving</strong>
        {' '}{SITE.areasServed.join(', ')}, {SITE.areasServedTagline}.
      </p>
      <p>
        <strong>Not medical advice.</strong> This website is for informational purposes only and is not a substitute
        for professional medical advice, diagnosis, or treatment. In a medical emergency, call 911 or go to the
        nearest emergency room.
      </p>
      <p>
        © {year} {SITE.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
