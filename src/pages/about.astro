---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import PageDecor from '../components/PageDecor.astro';
import AffiliationsStrip from '../components/AffiliationsStrip.astro';
import OfficeGallery from '../components/OfficeGallery.astro';
import Picture from '../components/Picture.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../site.config';

const values = [
  { icon: 'lucide:heart',         title: 'Family-centered',  body: 'You know your child best. We listen, explain, and partner with you on every decision.' },
  { icon: 'lucide:shield-check',  title: 'Evidence-based',   body: 'Care guided by current pediatric research and CDC immunization recommendations.' },
  { icon: 'lucide:clock',         title: 'Easy to access',   body: 'Same-day sick visits, online booking via patient portal, and a team that responds.' },
  { icon: 'lucide:users',         title: 'A pediatric home', body: 'One trusted practice for your child — from their very first newborn visit through young adulthood.' },
];
---
<BaseLayout
  title="About Luma Pediatrics | McKinney Pediatrician"
  path="/about"
  description="Luma Pediatrics is a board-certified pediatric practice opening in McKinney, TX. Warm, evidence-based pediatric care for newborns through age 21."
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'About', path: '/about' },
  ]}
>
  <section class="page-hero py-14 md:py-20 overflow-hidden">
    <PageDecor />
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
      <span class="eyebrow">About</span>
      <h1 class="mt-5 text-4xl md:text-5xl tracking-tight">
        Care that takes the time to know your family.
      </h1>
      <p class="mt-6 tagline-italic-sage text-lg md:text-xl">
        {SITE.tagline}
      </p>
      <p class="mt-7 text-lg text-[var(--color-foreground)]/80 leading-relaxed max-w-2xl mx-auto">
        Luma Pediatrics is a board-certified, physician-led pediatric practice opening in
        {' '}{SITE.locationShort}. We provide primary pediatric care for newborns through age 21,
        including well-child visits, same-day sick care, vaccinations, and adolescent health.
      </p>
    </div>
  </section>

  <!-- VALUES -->
  <section class="py-16 md:py-20 reveal relative overflow-hidden">
    <PageDecor variant="minimal" sparkles={6} />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {values.map(({ icon, title, body }) => (
          <article class="card-lift rounded-[var(--radius-card)] bg-[var(--color-card)] p-6">
            <span
               class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-[var(--color-muted)] text-[var(--color-primary)] mb-5 ring-1 ring-inset ring-[rgba(11,29,58,0.08)]"
              style="box-shadow: inset 0 1px 1px rgba(255,255,255,0.6);"
            >
              <Icon name={icon} class="w-6 h-6" stroke-width="1.6" aria-hidden="true" />
            </span>
            <h2 class="text-lg font-bold">{title}</h2>
            <p class="mt-2 text-[var(--color-foreground)]/80 leading-relaxed">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- OUR APPROACH -->
  <section class="py-20 md:py-28 bg-[var(--color-muted)] reveal relative overflow-hidden">
    <PageDecor variant="soft" sparkles={8} />
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <span class="eyebrow eyebrow-sun">Our approach</span>
      <h2 class="mt-5 text-3xl md:text-4xl font-extrabold tracking-tight">
        Modern medicine. Gentle bedside manner.
      </h2>
      <div class="mt-7 space-y-5 text-lg text-[var(--color-foreground)]/85 leading-relaxed">
        <p>
          We see every child as a whole person — not a chart, not a checklist. From the very first newborn visit,
          our goal is to build a trusting relationship that lasts through adolescence and beyond.
        </p>
        <p>
          That means longer first visits, real conversations, and an open line of communication for the questions
          that always come up between appointments. It means modern, evidence-based care delivered with the kind
          of warmth that turns a clinic into a place your kids actually like going.
        </p>
        <p>
          Our practice is physician-led, with a small, focused team.
          <a href="/new-patients">See accepted insurance plans →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- MEET THE PEDIATRICIAN -->
  <section class="provider-spotlight py-20 md:py-28 reveal relative overflow-hidden">
    <PageDecor variant="minimal" sparkles={6} />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      {SITE.showProviderProfile ? (
        <div class="provider-card grid gap-10 lg:grid-cols-[0.8fr_1.2fr] items-center p-6 md:p-10">
          <div class="provider-photo-stack" aria-label={`Portrait of ${SITE.provider.name}`}>
            <Picture src="/images/provider-headshot.jpg" alt={`${SITE.provider.name}, ${SITE.provider.role} at Luma Pediatrics`} loading="lazy" />
          </div>

          <div>
            <span class="eyebrow">Meet your pediatrician</span>
            <h2 class="mt-5 text-xl md:text-2xl lg:text-[1.875rem] tracking-tight whitespace-nowrap">{SITE.provider.name}</h2>
            <p class="mt-3 text-lg font-semibold text-[var(--color-sage-light)]">{SITE.provider.role}</p>
            <p class="mt-6 text-lg text-[var(--color-foreground)]/82 leading-relaxed">
              {SITE.provider.intro}
            </p>

            <ul class="provider-detail-list mt-7">
              {SITE.provider.education.map((item) => (
                <li>
                  <Icon name="lucide:graduation-cap" class="w-5 h-5 mt-1 shrink-0 text-[var(--color-sun)]" stroke-width="1.8" aria-hidden="true" />
                  <span>{item}</span>
                </li>
              ))}
              {SITE.provider.personal && (
                <li>
                  <Icon name="lucide:heart" class="w-5 h-5 mt-1 shrink-0 text-[var(--color-sun)]" stroke-width="1.8" aria-hidden="true" />
                  <span>{SITE.provider.personal}</span>
                </li>
              )}
              {SITE.provider.languages.length > 0 && (
                <li>
                  <Icon name="lucide:users" class="w-5 h-5 mt-1 shrink-0 text-[var(--color-sun)]" stroke-width="1.8" aria-hidden="true" />
                  <span>Additional languages include {SITE.provider.languages.join(', ')}.</span>
                </li>
              )}
            </ul>

            <div class="mt-8">
              <AffiliationsStrip />
            </div>

            <div class="mt-8 flex flex-wrap gap-3">
              <Button href={SITE.bookingUrl} variant="primary" ariaLabel="Book an appointment (opens healow)">
                <Icon name="lucide:calendar-check" class="w-5 h-5" stroke-width="1.6" />
                Book appointment
              </Button>
              <Button href="/contact" variant="secondary">Get in touch</Button>
            </div>
          </div>
        </div>
      ) : (
        <div class="provider-card grid gap-8 p-8 md:p-12 text-center">
          <div>
            <span class="eyebrow">Meet your pediatrician</span>
            <h2 class="mt-5 text-2xl md:text-3xl tracking-tight">
              Provider profile coming soon
            </h2>
            <p class="mt-6 text-lg text-[var(--color-foreground)]/82 leading-relaxed max-w-2xl mx-auto">
              Luma Pediatrics is led by a board-certified pediatrician with a warm,
              family-centered approach. Full provider profile, photo, and credentials
              will be shared on the site closer to opening day.
            </p>

            <div class="mt-8 max-w-3xl mx-auto">
              <AffiliationsStrip />
            </div>

            <div class="mt-8 flex flex-wrap gap-3 justify-center">
              <Button href="/contact" variant="primary">Get in touch</Button>
              <Button href="/new-patients" variant="secondary">New patient info</Button>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- INSIDE LUMA — office / care-feel gallery -->
  <section class="py-16 md:py-20 reveal relative overflow-hidden">
    <PageDecor variant="minimal" sparkles={8} />
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <span class="eyebrow eyebrow-sun">Inside Luma</span>
        <h2 class="mt-5 text-3xl md:text-4xl tracking-tight">
          A bright, calm place for kids to come.
        </h2>
        <p class="mt-5 text-[var(--color-foreground)]/80 leading-relaxed">
          Warm tones, gentle textures, and kid-friendly details designed to make every visit feel safe.
        </p>
      </div>
      <OfficeGallery />
    </div>
  </section>
</BaseLayout>
