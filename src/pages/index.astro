---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import StarDivider from '../components/StarDivider.astro';
import SageWave from '../components/SageWave.astro';
import SparkleField from '../components/SparkleField.astro';
import WaitlistForm from '../components/WaitlistForm.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../site.config';
import { featuredServices as services } from '../data/services';
import Picture from '../components/Picture.astro';

const promises = [
  {
    icon: 'lucide:clock',
    title: 'Unhurried, attentive visits',
    body: 'Longer appointment times by design, so every question is heard and every concern is addressed with care.',
  },
  {
    icon: 'lucide:users',
    title: 'Continuity of care',
    body: 'Your child sees the same pediatrician at every visit — building a trusted relationship that grows with your family.',
  },
  {
    icon: 'lucide:heart',
    title: 'Partnership with parents',
    body: 'Clear guidance, honest answers, and a clinical team that listens. We support the decisions you make for your child.',
  },
];

const expectations = [
  {
    icon: 'lucide:clock',
    title: 'Thoughtful, unhurried visits',
    body: 'Appointment times are intentionally longer so every concern is examined carefully and every question receives a complete answer.',
  },
  {
    icon: 'lucide:calendar',
    title: 'Schedules that work for families',
    body: 'Weekday hours from 7:30 am and Saturday mornings make it easier to schedule routine and same-day visits without disrupting school or work.',
  },
  {
    icon: 'lucide:message-circle',
    title: 'Direct, secure communication',
    body: 'Reach our clinical team by phone, secure text, or patient portal during office hours — without phone trees or long hold times.',
  },
  {
    icon: 'lucide:users',
    title: 'Continuity with your pediatrician',
    body: 'Your child sees the same board-certified pediatrician at every visit, supporting accurate diagnosis, consistent care, and a trusted long-term relationship.',
  },
  {
    icon: 'lucide:shield-check',
    title: 'Evidence-based pediatric medicine',
    body: 'Care guided by current AAP and CDC recommendations, delivered with clear explanations so families understand every decision.',
  },
  {
    icon: 'lucide:hospital',
    title: 'Newborn rounds at BSW McKinney',
    body: 'In-hospital newborn visits at Baylor Scott & White Medical Center – McKinney, ensuring a seamless transition from the hospital to your pediatric home.',
  },
  {
    icon: 'lucide:siren',
    title: 'Pediatric specialty access',
    body: "When advanced care is needed, we coordinate referrals to North Texas's leading children's hospitals and pediatric subspecialists.",
  },
  {
    icon: 'lucide:handshake',
    title: 'Complimentary Meet & Greet',
    body: 'Tour the practice and meet your pediatrician before establishing care — an opportunity to ensure Luma is the right fit for your family.',
  },
];

const trustPhotos = [
  {
    src: '/images/trust-family.jpg',
    alt: 'A mother cuddling her happy laughing baby in a soft, sunlit nursery',
    title: 'Family centered',
    body: 'Care built around the people who know your child best.',
  },
  {
    src: '/images/trust-checkup.jpg',
    alt: 'A pediatrician using a stethoscope on a smiling girl held by her mother',
    title: 'Gentle visits',
    body: 'Unhurried, kid-friendly appointments from day one.',
  },
  {
    src: '/images/trust-gentle.jpg',
    alt: 'A smiling young girl using a stethoscope to listen to her teddy bear',
    title: 'Confidence in care',
    body: 'A calm space where curious kids feel safe to explore.',
  },
  {
    src: '/images/trust-playful.jpg',
    alt: 'A happy toddler sitting on a rug, surrounded by a teddy bear, bunny, and stacking toys',
    title: 'Bright and playful',
    body: 'A welcoming clinic designed to feel like home.',
  },
];
---
<BaseLayout
  title="Pediatrician in McKinney, TX | Newborns to Teens"
  path="/"
  description="Luma Pediatrics is a board-certified pediatric practice opening in McKinney, TX. We serve newborns through age 21 with well-child visits, same-day sick care, vaccinations, school physicals, and ADHD/behavioral support. Now accepting new patients."
>

  <!-- ====================================================================
       HERO — elegant brand vibe: centered logo + serif wordmark + italic
       gold tagline, gold sparkles scattered, sage-curved transition below.
       ==================================================================== -->
  <section class="brand-hero overflow-hidden">
    <div class="brand-cloud cloud-left" aria-hidden="true"></div>
    <div class="brand-cloud cloud-right" aria-hidden="true"></div>
    <div class="botanical-spray leaf-left" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <div class="botanical-spray leaf-right" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <SparkleField count={12} class="z-0" />

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-10 flex-1 flex items-center">
      <div class="fade-up grid gap-8 lg:grid-cols-[0.92fr_1.08fr] items-center w-full">
        <div class="text-center lg:text-left">
          <p class="hero-status-pill">
            <Icon name="lucide:sparkles" class="w-3.5 h-3.5" stroke-width="2" aria-hidden="true" />
            <span>Now accepting new patients · Opening {SITE.openingWindow} in {SITE.locationShort.split(',')[0]}</span>
          </p>
          <h1 class="mt-4 text-4xl md:text-6xl font-semibold tracking-tight leading-[0.98]" style="font-family: var(--font-display);">
            Compassionate care for every stage.
          </h1>
          <div class="mt-5 lg:max-w-xs">
            <StarDivider span="4rem" />
          </div>
          <p class="mt-5 text-lg md:text-2xl tagline-italic-sage leading-snug">
            Where your child's health shines.
          </p>
          <p class="mt-4 text-base md:text-lg text-[var(--color-foreground)]/80 max-w-xl mx-auto lg:mx-0 leading-relaxed">
            Luma Pediatrics is an independent pediatric practice opening in {SITE.locationShort.split(',')[0]},
            offering comprehensive care for newborns through young adulthood —
            from well-child visits and immunizations to same-day sick care.
          </p>

          <div class="mt-6 flex flex-wrap justify-center lg:justify-start gap-3">
            <Button href={SITE.bookingUrl} variant="primary" ariaLabel="Book an appointment (opens healow)">
              <Icon name="lucide:calendar-check" class="w-5 h-5" stroke-width="1.6" />
              Book appointment
            </Button>
            <Button href="/services" variant="secondary">
              Explore services
              <span class="btn-icon-circle" aria-hidden="true">
                <Icon name="lucide:arrow-right" class="w-4 h-4" stroke-width="1.8" />
              </span>
            </Button>
          </div>
          <p class="mt-4 text-xs text-[var(--color-muted-foreground)]">
            Booking opens our secure patient portal at healow.com.
          </p>
        </div>

        <figure class="hero-poster-image">
          <Picture src="/images/hero-poster.jpg" alt="Luma Pediatrics — Opening Soon in McKinney, TX. Where your child's health shines." loading="eager" fetchpriority="high" />
        </figure>
      </div>
    </div>

    <div class="sage-sweep" aria-hidden="true"></div>
    <!-- Sage wave transition into the next section -->
    <SageWave direction="down" height={38} />
  </section>

  <!-- ====================================================================
       TRUST-BUILDING PHOTO STRIP — warm faces and safe, happy care moments.
       ==================================================================== -->
  <section class="trust-gallery py-20 md:py-28 reveal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] items-end mb-12">
        <div>
          <span class="eyebrow eyebrow-sun">Warm, safe, attentive</span>
          <h2 class="mt-5 text-4xl md:text-6xl tracking-tight">
            A welcoming environment for every visit.
          </h2>
        </div>
        <p class="text-lg text-[var(--color-foreground)]/78 leading-relaxed max-w-2xl lg:ml-auto">
          Our practice is designed to feel calm, bright, and reassuring — a place where children
          are comfortable and parents feel supported. Thoughtful, unhurried visits delivered with
          the warmth and professionalism your family deserves.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {trustPhotos.map(({ src, alt, title, body }) => (
          <figure class="photo-trust-card card-lift">
            <Picture src={src} alt={alt} loading="lazy" />
            <figcaption>
              <h3>{title}</h3>
              <p>{body}</p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================================
       SERVICES preview
       ==================================================================== -->
  <section id="services" class="py-20 md:py-28 reveal relative">
    <SparkleField count={6} />
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-14">
        <span class="eyebrow">What we do</span>
        <h2 class="mt-5 text-3xl md:text-5xl tracking-tight">Care at every stage</h2>
        <p class="mt-5 tagline-italic-sage text-lg md:text-xl">
          From your child's first checkup through young adulthood.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map(({ icon, title, short, badge }) => (
          <article class="card-lift group rounded-[var(--radius-card)] bg-[var(--color-card)] p-7">
            <span
              class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-muted)] text-[var(--color-primary)] mb-5 ring-1 ring-inset ring-[rgba(200, 153, 90,0.30)]"
              style="box-shadow: inset 0 1px 1px rgba(255,255,255,0.6);"
            >
              <Icon name={icon} class="w-6 h-6" stroke-width="1.6" aria-hidden="true" />
            </span>
            <div class="flex items-center gap-2 flex-wrap">
              <h3 class="text-2xl font-semibold" style="font-family: var(--font-display);">{title}</h3>
              {badge && (
                <span class="service-badge">{badge}</span>
              )}
            </div>
            <p class="mt-2.5 text-[var(--color-foreground)]/80 leading-relaxed">{short}</p>
          </article>
        ))}
      </div>

      <div class="mt-10 text-center">
        <Button href="/services" variant="secondary">
          See all services
          <span class="btn-icon-circle" aria-hidden="true">
            <Icon name="lucide:arrow-right" class="w-4 h-4" stroke-width="1.8" />
          </span>
        </Button>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       EXPERIENCE — generic trust band (employer-safe pre-launch)
       ==================================================================== -->
  <section class="py-10 md:py-12 bg-[var(--color-sage-light)]/40 border-y border-[var(--color-border-soft)] reveal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-base md:text-lg text-luma-ink/85 leading-relaxed">
        <Icon name="lucide:award" class="inline w-5 h-5 -mt-1 text-luma-gold" />
        {' '}<strong class="font-semibold">{SITE.provider.experienceLine}</strong>
        {' '}Board-certified pediatric care, grounded in current AAP and CDC clinical guidelines.
      </p>
    </div>
  </section>

  <!-- ====================================================================
       WHAT TO EXPECT — conversational, empathy-led trust block
       ==================================================================== -->
  <section class="py-20 md:py-28 reveal relative">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-12">
        <span class="eyebrow">What to expect</span>
        <h2 class="mt-5 text-3xl md:text-5xl tracking-tight">Comprehensive, evidence-based pediatric care.</h2>
        <p class="mt-5 text-lg text-[var(--color-foreground)]/78 leading-relaxed">
          A clinical model built around continuity, accessibility, and the highest standards of
          modern pediatric medicine.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {expectations.map(({ icon, title, body }) => (
          <article class="rounded-[var(--radius-card)] bg-[var(--color-card)] p-7 card-lift">
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-muted)] text-[var(--color-primary)] mb-4">
              <Icon name={icon} class="w-6 h-6" stroke-width="1.6" aria-hidden="true" />
            </span>
            <h3 class="text-xl font-semibold mb-2" style="font-family: var(--font-display);">{title}</h3>
            <p class="text-[var(--color-foreground)]/80 leading-relaxed">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================================
       WAITLIST — pre-launch founding-families capture
       ==================================================================== -->
  <section class="py-16 md:py-20 reveal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <WaitlistForm variant="hero" />
    </div>
  </section>

  <!-- ====================================================================
       INSURANCE — gold-tinted band with elegant treatment
       ==================================================================== -->
  <section class="py-16 md:py-20 bg-[var(--color-muted)] reveal">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="eyebrow eyebrow-sun">Insurance</span>
      <h2 class="mt-5 text-3xl md:text-4xl tracking-tight">
        Major insurance welcome.
      </h2>
      <StarDivider class="mt-7" span="3rem" />
      <p class="mt-7 text-[var(--color-foreground)]/80 max-w-2xl mx-auto leading-relaxed text-lg">
        We work with major insurance providers and self-pay families across North Dallas and Collin County.
      </p>
      <div class="mt-7">
        <a href="/new-patients" class="font-semibold text-[var(--color-primary)] underline-offset-4 hover:underline">
          See accepted plans & new patient info →
        </a>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       OUR PROMISE — values-led block (replaces testimonials pre-launch;
       we'll add real, attributed reviews after launch with consent).
       ==================================================================== -->
  <section aria-label="Our promise to your family" class="py-20 md:py-28 reveal relative navy-campaign">
    <SparkleField count={8} />
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-14">
        <span class="eyebrow eyebrow-sun">Our commitment</span>
        <h2 class="mt-5 text-3xl md:text-5xl tracking-tight text-white">The standards we hold ourselves to</h2>
        <p class="mt-5 text-white/85 leading-relaxed text-lg">
          As a new practice, we earn families' trust through the standard of care we provide.
          These are the commitments you can count on at every visit.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {promises.map(({ icon, title, body }) => (
          <article class="card-lift navy-card rounded-[var(--radius-card)] p-8">
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-white/15 text-[var(--color-sun)] mb-5" aria-hidden="true">
              <Icon name={icon} class="w-6 h-6" stroke-width="1.6" />
            </span>
            <h3 class="text-xl font-semibold text-white mb-3" style="font-family: var(--font-display);">{title}</h3>
            <p class="text-white/85 leading-relaxed">{body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ====================================================================
       FINAL CTA — "Still have questions?" pairing FAQ + Contact, instead of
       duplicating the hero. Keeps a strong close without repeating CTAs.
       ==================================================================== -->
  <section class="campaign-panel">
    <div class="brand-cloud cloud-right" aria-hidden="true"></div>
    <div class="botanical-spray leaf-right" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span>
    </div>
    <SparkleField count={10} />

    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 text-center">
      <div class="campaign-card px-5 py-12 md:p-14">
        <span class="eyebrow eyebrow-sun">Still have questions?</span>
        <h2 class="mt-5 text-3xl md:text-5xl tracking-tight" style="font-family: var(--font-display);">
          We're here to help your family feel at home.
        </h2>
        <StarDivider class="mt-7" span="3rem" />
        <p class="mt-7 text-base md:text-lg text-[var(--color-foreground)]/78 max-w-2xl mx-auto leading-relaxed">
          Browse our FAQ for quick answers, or reach out — we typically reply within one business day.
        </p>
        <div class="mt-9 flex flex-wrap justify-center gap-3">
          <Button href="/faq" variant="primary">
            <Icon name="lucide:info" class="w-5 h-5" stroke-width="1.6" />
            Read our FAQ
          </Button>
          <Button href="/contact" variant="secondary">
            Contact us
            <span class="btn-icon-circle" aria-hidden="true">
              <Icon name="lucide:arrow-right" class="w-4 h-4" stroke-width="1.8" />
            </span>
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
