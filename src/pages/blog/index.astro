---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageDecor from '../../components/PageDecor.astro';
import Picture from '../../components/Picture.astro';
import { Icon } from 'astro-icon/components';
import { SITE } from '../../site.config';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

const description =
  'Pediatric guidance for parents across North Dallas and Collin County — from newborn care to fevers, sleep, vaccines, and more. Written by the Luma Pediatrics clinical team.';
---
<BaseLayout
  title="Parent Resources & Blog"
  description={description}
  path="/blog/"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Parent Resources', path: '/blog/' },
  ]}
>
  <PageDecor />

  <section class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 sm:pt-20 pb-10">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-accent)]">
      Parent Resources
    </p>
    <h1 class="mt-3 font-display text-4xl sm:text-5xl text-[var(--color-primary)]">
      Calm, practical pediatric guidance
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-[var(--color-muted-foreground)] leading-relaxed">
      Straightforward articles from our pediatric team on the questions parents
      ask us most — fevers, sleep, newborn care, vaccines, and when to call.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-10">
    <a
      href="/dosing-charts/"
      class="block rounded-2xl border-2 border-[var(--color-accent)] bg-[var(--color-accent)]/5 p-6 sm:p-7 no-underline hover:bg-[var(--color-accent)]/10 transition-colors"
    >
      <div class="flex items-start gap-4">
        <div class="shrink-0 w-12 h-12 rounded-xl bg-[var(--color-accent)]/15 flex items-center justify-center">
          <Icon name="lucide:pill" class="w-6 h-6 text-[var(--color-accent)]" stroke-width="2" aria-hidden="true" />
        </div>
        <div class="flex-1">
          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-accent)]">
            Quick reference
          </p>
          <h2 class="mt-1 font-display text-2xl text-[var(--color-primary)] leading-snug">
            Pediatric OTC dosing charts
          </h2>
          <p class="mt-1 text-[var(--color-muted-foreground)]">
            Weight-based dosing for Tylenol, Motrin/Advil, and Benadryl —
            printable, mobile-friendly, AAP-sourced.
          </p>
        </div>
        <Icon name="lucide:arrow-right" class="w-5 h-5 text-[var(--color-accent)] mt-2 shrink-0" stroke-width="2" aria-hidden="true" />
      </div>
    </a>
  </section>

  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    {posts.length === 0 ? (
      <p class="text-[var(--color-muted-foreground)]">Posts coming soon.</p>
    ) : (
      <ul class="grid gap-8 sm:grid-cols-2">
        {posts.map((post) => {
          const date = post.data.publishDate.toLocaleDateString('en-US', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <li class="blog-card reveal">
              <a href={`/blog/${post.id}/`} class="block no-underline">
                {post.data.hero && (
                  <figure class="blog-card-figure">
                    <Picture
                      src={post.data.hero}
                      alt={post.data.heroAlt ?? post.data.title}
                      loading="lazy"
                    />
                  </figure>
                )}
                <div class="p-5">
                  <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-muted-foreground)]">
                    {date}
                  </p>
                  <h2 class="mt-2 font-display text-2xl text-[var(--color-primary)] leading-snug">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-sm text-[var(--color-muted-foreground)] leading-relaxed">
                    {post.data.description}
                  </p>
                  <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-accent)]">
                    Read article
                    <Icon name="lucide:arrow-right" class="w-4 h-4" stroke-width="2" aria-hidden="true" />
                  </span>
                </div>
              </a>
            </li>
          );
        })}
      </ul>
    )}

    <p class="mt-12 text-xs text-[var(--color-muted-foreground)] text-center max-w-2xl mx-auto leading-relaxed">
      Articles on this site are for general educational purposes only and are
      not a substitute for personalized advice from your child's pediatrician.
      For urgent concerns, call {SITE.contact.phone} or go to the nearest emergency room.
    </p>
  </section>
</BaseLayout>

<style>
  .blog-card {
    border-radius: 1.25rem;
    overflow: hidden;
    background: var(--color-background);
    border: 1px solid rgba(11, 29, 58, 0.08);
    box-shadow: 0 6px 18px rgba(11, 29, 58, 0.05);
    transition: transform 250ms ease, box-shadow 250ms ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 30px rgba(11, 29, 58, 0.10);
  }
  .blog-card-figure {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin: 0;
  }
  .blog-card-figure :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms ease;
  }
  .blog-card:hover .blog-card-figure :global(img) {
    transform: scale(1.04);
  }
</style>
