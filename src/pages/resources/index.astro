---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageDecor from '../../components/PageDecor.astro';
import { Icon } from 'astro-icon/components';

const sections = [
  {
    href: '/health-watch',
    eyebrow: 'Local conditions',
    title: 'Health Watch',
    body:
      'A daily snapshot of air quality, pollen, and respiratory illness activity across North Collin County, written in plain language for parents.',
    icon: 'lucide:activity',
  },
  {
    href: '/dosing-charts',
    eyebrow: 'Quick reference',
    title: 'Dosing Charts',
    body:
      'Weight-based acetaminophen and ibuprofen dosing tables for children, with clear age, weight, and dose guidance.',
    icon: 'lucide:pill',
  },
  {
    href: '/blog',
    eyebrow: 'Articles',
    title: 'Blog & Parent Guides',
    body:
      'Pediatric guidance from the Luma clinical team — newborn care, fevers, sleep, vaccines, and the everyday questions parents ask most.',
    icon: 'lucide:book-open',
  },
];
---
<BaseLayout
  title="Resources for Parents"
  description="Health Watch, dosing charts, and parent guides from Luma Pediatrics — quick references and clear answers for North Collin County families."
  path="/resources/"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Resources', path: '/resources/' },
  ]}
>
  <PageDecor />

  <section class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 sm:pt-20 pb-10">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-accent)]">
      Resources
    </p>
    <h1 class="mt-3 font-display text-4xl sm:text-5xl text-[var(--color-primary)]">
      Trusted information for parents.
    </h1>
    <p class="mt-4 text-lg text-[var(--color-foreground)]/80 leading-relaxed max-w-3xl">
      Quick references, local health updates, and parent guides — all in one place.
    </p>
  </section>

  <section class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <div class="grid gap-6 md:grid-cols-3">
      {sections.map(({ href, eyebrow, title, body, icon }) => (
        <a
          href={href}
          class="group rounded-[var(--radius-card)] bg-[var(--color-card)] p-7 card-lift no-underline border border-[var(--color-border-soft)] flex flex-col"
        >
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-muted)] text-[var(--color-primary)] mb-4" aria-hidden="true">
            <Icon name={icon} class="w-6 h-6" stroke-width="1.6" />
          </span>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-accent)]">{eyebrow}</p>
          <h2 class="mt-2 text-2xl font-semibold text-[var(--color-foreground)]" style="font-family: var(--font-display);">{title}</h2>
          <p class="mt-3 text-[var(--color-foreground)]/80 leading-relaxed flex-1">{body}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-[var(--color-primary)] font-medium">
            Explore
            <Icon name="lucide:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" stroke-width="1.8" aria-hidden="true" />
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
